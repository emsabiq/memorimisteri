# Server
PORT=3035
PUBLIC_BASE_URL=https://mistis.emsa.pro
AUTO_DASHBOARD_PIN=123456

# Providers are optional. Without OPENAI_API_KEY, the app runs in offline draft mode.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
STORY_MODEL=gpt-4.1-mini
IMAGE_MODEL=gpt-image-1-mini
IMAGE_SIZE=1024x1536
IMAGE_QUALITY=low
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=shimmer
OPENAI_TRANSCRIBE_MODEL=whisper-1
TTS_EFFECTS_ENABLED=true
MISTIS_TTS_PROVIDER=openai
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=pFZP5JQG7iQjIQuC4Bku
ELEVENLABS_TTS_USD_PER_1K_CHARS=0.1

# Cost estimator defaults. Keep these configurable because provider pricing can change.
STORY_INPUT_USD_PER_1M_TOKENS=0.40
STORY_OUTPUT_USD_PER_1M_TOKENS=1.60
TTS_USD_PER_1M_CHARS=15

# Automation is intentionally disabled for the first phase.
AUTOMATION_ENABLED=false
DAILY_PART_UPLOAD_ENABLED=false
PART_UPLOAD_RETRY_MINUTES=15
SOCIAL_ACCOUNT_NAME=memorimisteri
MISTIS_RESET_EPISODE_STATE=false
YOUTUBE_UPLOAD_ENABLED=false
FACEBOOK_UPLOAD_ENABLED=false
INSTAGRAM_UPLOAD_ENABLED=false
THREADS_UPLOAD_ENABLED=false

# Bundled horror render assets. Leave blank to use public/assets defaults.
SCHOLAR_FONT_PATH=
SCHOLAR_ITALIC_FONT_PATH=
SUBTITLE_FONT_FAMILY=Scholar
HORROR_AUDIO_DIR=
HORROR_MUSIC_FILES=
JUMPSCARE_SFX_FILES=
PRODUCER_MUSIC_VOLUME=0.42

# Public hosting path for Meta-fetchable media URLs.
UPLOAD_DRIVER=ftp
FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASSWORD=
FTP_REMOTE_DIR=/public_html/mistis
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_PASSWORD=
SFTP_REMOTE_DIR=/public_html/mistis

# Meta publishing tokens. Use memorimisteri accounts/page.
GRAPH_API_VERSION=v25.0
FACEBOOK_MEDIA_TYPE=reel
FACEBOOK_VIDEO_STATE=PUBLISHED
FACEBOOK_MEDIA_SETTLE_SECONDS=90
MISTIS_FACEBOOK_PAGE_ID=
MISTIS_FACEBOOK_PAGE_ACCESS_TOKEN=
MISTIS_FACEBOOK_USER_ACCESS_TOKEN=
MISTIS_INSTAGRAM_IG_USER_ID=17841435998195290
MISTIS_INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_IG_USER_ID=17841435998195290
INSTAGRAM_SHARE_TO_FEED=true
INSTAGRAM_MAX_DURATION_SECONDS=90
INSTAGRAM_CONTAINER_POLL_SECONDS=6
INSTAGRAM_CONTAINER_MAX_ATTEMPTS=90
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=
THREADS_GRAPH_BASE_URL=https://graph.threads.net/v1.0

# Fan story inbox.
FAN_STORY_MIN_TEXT_CHARS=250
FAN_STORY_MIN_AUDIO_SECONDS=20
FAN_STORY_MAX_UPLOAD_MB=50
